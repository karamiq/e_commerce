  "additionalPrice": 100,
  "stockQuantity": 45,
  "isActive": true,
  "imageUrl": "https://example.com/images/iphone15pro-black.jpg",
  "attributeValueIds": [
    "{{createBlackValue.response.body.id}}",
    "{{create256GBValue.response.body.id}}"
  ]
}

