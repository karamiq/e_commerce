@baseUrl = http://localhost:3000/api
@token = YOUR_ACCESS_TOKEN_HERE
@colorAttributeId = 99af89e5-11ef-4775-96c8-9525ae0ff023
@sizeAttributeId = 1d04b546-d525-482f-9525-bce024e0d3ea
