@baseUrl = http://localhost:3000/api
@token = YOUR_ACCESS_TOKEN_HERE
@productId = e51fefc9-1163-44b4-ac21-b1d2a31075ce
@blackValueId = dceea951-18bf-4a9d-84f5-e03831a4d2a5
@whiteValueId = 514fa289-646d-4338-aef3-0dd7b219a8d0
@silverValueId = f50d92fc-7914-4e3f-9e80-34500ca012ee
@goldValueId = 52a36a18-15d0-4ef1-8070-66dd82b3d4bc
